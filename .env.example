# Copy this file to ".env" and fill in your Supabase project details.
# Both values are in your Supabase dashboard: Project Settings -> API.
# The anon key is the PUBLIC key and is safe to ship in a frontend.
#
# Leave these blank to run the app against bundled DEMO data (no database needed).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
